NEXT_PUBLIC_DOC_URL=https://docs.canvas.best

# Canvas 公开地址与 Token/New API 服务地址
CANVAS_PUBLIC_ORIGIN=https://canvas.mewinyou.shop
TOKEN_ISSUER_URL=https://token.mewinyou.shop
TOKEN_API_BASE_URL=https://token.mewinyou.shop

# 必须与 Token/New API 服务端配置完全一致
CANVAS_OAUTH_CLIENT_ID=canvas
CANVAS_OAUTH_CLIENT_SECRET=replace_with_a_long_random_secret
CANVAS_OAUTH_REDIRECT_URI=https://canvas.mewinyou.shop/auth/callback

# 32 字节随机密钥：base64 或 64 位十六进制；用于加密会话中的 Token API Key
CANVAS_ENCRYPTION_KEY=replace_with_32_byte_base64_or_64_hex_key
CANVAS_SESSION_TTL_SECONDS=2592000
CANVAS_DATA_DIR=/app/data
